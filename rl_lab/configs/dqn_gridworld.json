{
  "experiment_name": "dqn_gridworld",
  "agent": "dqn",
  "env": "gridworld",
  "env_kwargs": {
    "size": 8,
    "obstacle_density": 0.15,
    "max_steps": 200,
    "goal_reward": 1.0,
    "step_penalty": -0.01,
    "obstacle_penalty": -0.05
  },
  "agent_kwargs": {
    "hidden_sizes": [128, 128],
    "lr": 0.001,
    "gamma": 0.99,
    "buffer_capacity": 50000,
    "batch_size": 64,
    "target_update_freq": 500,
    "eps_start": 1.0,
    "eps_end": 0.05,
    "eps_decay_steps": 10000,
    "grad_clip": 10.0
  },
  "training": {
    "n_episodes": 500,
    "eval_every": 50,
    "eval_episodes": 20,
    "checkpoint_every": 100,
    "log_every": 10,
    "device": "cpu",
    "seed": 42
  },
  "output_dir": "runs/dqn_gridworld"
}
