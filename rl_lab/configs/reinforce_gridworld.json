{
  "experiment_name": "reinforce_gridworld",
  "agent": "reinforce",
  "env": "gridworld",
  "env_kwargs": {
    "size": 8,
    "obstacle_density": 0.15,
    "max_steps": 200,
    "goal_reward": 1.0,
    "step_penalty": -0.01,
    "obstacle_penalty": -0.05
  },
  "agent_kwargs": {
    "hidden_sizes": [128, 128],
    "actor_lr": 0.0003,
    "critic_lr": 0.001,
    "gamma": 0.99,
    "entropy_coef": 0.01,
    "grad_clip": 1.0
  },
  "training": {
    "n_episodes": 500,
    "eval_every": 50,
    "eval_episodes": 20,
    "checkpoint_every": 100,
    "log_every": 10,
    "device": "cpu",
    "seed": 42
  },
  "output_dir": "runs/reinforce_gridworld"
}
