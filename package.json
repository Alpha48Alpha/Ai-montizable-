{
  "name": "ai-trailer-studio",
  "version": "1.0.0",
  "description": "AI-powered movie trailer generation platform",
  "private": true,
  "main": "api/server.js",
  "scripts": {
    "start": "node api/server.js",
    "worker": "node workers/worker.js",
    "dev:api": "nodemon api/server.js",
    "dev:worker": "nodemon workers/worker.js",
    "test": "jest --forceExit"
  },
  "dependencies": {
    "bull": "^4.12.2",
    "cors": "^2.8.5",
    "express": "^4.18.3",
    "express-rate-limit": "^8.3.1",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ]
  }
}
